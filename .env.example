# Environment variables
OPENAI_API_KEY=your_openai_api_key_here
HUGGING_FACE_HUB_TOKEN=your_hugging_face_token_here

# Model configuration
# DEFAULT_MODEL is used when no HUGGING_FACE_HUB_TOKEN is provided
# Use models that don't require authentication like:
# - microsoft/DialoGPT-medium (conversational)
# - distilgpt2 (lightweight)
# - gpt2 (classic)
DEFAULT_MODEL=microsoft/DialoGPT-medium
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API configuration
API_HOST=localhost
API_PORT=8000
LOG_LEVEL=INFO

# FAISS configuration
FAISS_INDEX_PATH=embeddings/faiss_index
KNOWLEDGE_BASE_PATH=data/knowledge_base
